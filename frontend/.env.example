# Base URL of the deployed backend (Render web service).
#
# Leave EMPTY for local dev — the Vite dev proxy (vite.config.js) forwards
# /api (including the SSE stream) to http://localhost:8080, so no CORS is needed.
#
# In production set this to your backend's public URL (NO trailing slash), e.g.
#   VITE_API_BASE=https://orderbook-backend.onrender.com
# Vite inlines VITE_* vars at build time, so changing this requires a rebuild.
VITE_API_BASE=
