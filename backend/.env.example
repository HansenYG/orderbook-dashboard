# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
# Comma-separated list of allowed CORS origins (Vite dev server by default).
# In production set this to your Vercel frontend URL, e.g.
#   CORS_ORIGIN=https://orderbook-dashboard.vercel.app
# Use "*" to allow any origin (convenient for a public demo).
CORS_ORIGIN=http://localhost:5173

# ── Ingestion ───────────────────────────────────────────────────────────────
# Set to 1 to force the offline synthetic simulator instead of real exchanges.
# (The simulator also auto-activates per-exchange after repeated connect failures.)
USE_SIMULATOR=0
# Number of orderbook levels to keep per side in the unified snapshot.
BOOK_LEVELS=20

# ── Storage backend ─────────────────────────────────────────────────────────
# If MONGODB_URI is set, the app uses MongoDB (durable alerts + settings; recent
# snapshots kept in an in-memory ring buffer). This is the hosted mode.
# Leave MONGODB_URI empty to use the local SQLite file instead (full snapshot
# history on disk — the default for local development).
#   MONGODB_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=orderbook
# How many recent snapshots per exchange to keep in memory for /api/snapshots
# when running in MongoDB mode (snapshots are not persisted to the cloud DB).
RECENT_BUFFER_SIZE=200

# ── Storage (SQLite mode, used only when MONGODB_URI is empty) ───────────────
DB_PATH=./data/orderbook.db
# Levels of depth persisted per side per row (<= BOOK_LEVELS).
STORE_LEVELS=20
# Batch writer: flush when this many rows are queued...
BATCH_MAX_ROWS=100
# ...or after this many milliseconds, whichever comes first.
BATCH_INTERVAL_MS=1000
# Safety cap on the in-memory write queue (drops oldest if disk stalls).
BATCH_QUEUE_CAP=20000
# "Store every update" is bounded by retention: rows older than this are pruned.
# NOTE: at ~10-25 updates/sec this DB can grow ~1-2 GB/day; lower this to bound disk.
RETENTION_HOURS=24
PRUNE_INTERVAL_MS=60000

# ── SSE streaming ────────────────────────────────────────────────────────────
# How often the throttled "tick" (latest book + metrics) is pushed to clients.
SSE_TICK_MS=150
# Heartbeat comment interval to keep SSE connections alive through proxies.
SSE_HEARTBEAT_MS=15000

# ── Alert default thresholds (persisted in DB on first run; editable via API) ─
ALERT_SPREAD_BPS=5
ALERT_IMBALANCE=0.6
ALERT_DISCREPANCY_PCT=0.1
# Minimum ms between repeat alerts of the same (type, exchange).
ALERT_COOLDOWN_MS=5000
